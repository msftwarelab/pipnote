{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pipnote",
  "version": "1.0.0",
  "identifier": "com.pipnote.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Pipnote - AI-Powered Knowledge Base",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "msi", "deb", "appimage"],
    "publisher": "Pipnote Team",
    "copyright": "Copyright © 2026 Pipnote Team",
    "category": "Productivity",
    "shortDescription": "AI-powered local-first knowledge base",
    "longDescription": "Pipnote is a privacy-focused, local-first AI knowledge base that organizes notes, links related ideas, and answers questions from your own files using your selected local AI provider.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "exceptionDomain": ""
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
