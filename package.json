{
  "name": "pipnote",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:editor": "node --test --experimental-strip-types tests/*.test.ts",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:headed": "env -u NO_COLOR playwright test --headed",
    "test:e2e:ui": "env -u NO_COLOR playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "release:check": "bash ./scripts/release-check.sh",
    "release:check:full": "bash ./scripts/release-check.sh --full",
    "release:artifacts": "bash ./scripts/release-artifacts.sh",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && bash ./scripts/package-macos-dmg.sh",
    "tauri:build:mac": "tauri build --target universal-apple-darwin --bundles app && bash ./scripts/package-macos-dmg.sh",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc"
  },
  "dependencies": {
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/cli": "^2.9.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
